#!/bin/bash
# coordinator-safe-commit — Scoped safety commit helper (Phase 3, scoped-safety-commits plan)
#
# Canonical invocation:
#   ~/.claude/plugins/coordinator-claude/coordinator/bin/coordinator-safe-commit "<subject>"
# Or alias in shell rc:
#   alias safe-commit='~/.claude/plugins/coordinator-claude/coordinator/bin/coordinator-safe-commit'
#
# Usage forms:
#   coordinator-safe-commit "<subject>"                   # default — scoped staging
#   coordinator-safe-commit --blanket "<subject>"         # blanket staging (carve-outs only)
#   coordinator-safe-commit --scope-from <path> "<subject>" # workstream-anchored (handoff/pickup)
#   coordinator-safe-commit --dry-run "<subject>"         # show what would be staged, no commit
#
# Environment:
#   CLAUDE_SESSION_ID            — session ID (highest priority source)
#   CLAUDE_INVOKING_COMMAND      — required for --blanket (must be session-start or workday-complete)
#   COORDINATOR_OVERRIDE_SCOPE=1 — emergency: stage all dirty files, logs override, skip subtraction
#
# See: ~/.claude/plans/scoped-safety-commits.md  (design)
#      ~/.claude/plans/review-scoped-safety-commits-patrik.md  (Patrik's review)

set -euo pipefail

# ---------------------------------------------------------------------------
# Library source
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB="${SCRIPT_DIR}/../lib/coordinator-session.sh"

if [[ ! -f "$LIB" ]]; then
  echo "ERROR: coordinator-session.sh not found at ${LIB}" >&2
  exit 1
fi
# shellcheck source=../lib/coordinator-session.sh
source "$LIB"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

MODE="default"       # default | blanket | scope-from | dry-run
SCOPE_FROM_PATH=""
SUBJECT=""

usage() {
  cat >&2 <<'USAGE'
Usage:
  coordinator-safe-commit "<subject>"
  coordinator-safe-commit --blanket "<subject>"
  coordinator-safe-commit --scope-from <handoff.md> "<subject>"
  coordinator-safe-commit --dry-run "<subject>"

Tip: If you're not sure what will be committed, run with --dry-run first.
     Files being skipped as "owned by another session" but you wrote them?
     Your session ID resolution is wrong — see
     ~/.claude/docs/wiki/scoped-safety-commits.md (troubleshooting section).
USAGE
  exit 1
}

# Parse flags before subject
while [[ $# -gt 0 ]]; do
  case "$1" in
    --blanket)
      MODE="blanket"
      shift
      ;;
    --scope-from)
      MODE="scope-from"
      if [[ $# -lt 2 ]]; then
        echo "ERROR: --scope-from requires a path argument." >&2
        exit 1
      fi
      SCOPE_FROM_PATH="$2"
      shift 2
      ;;
    --dry-run)
      MODE="dry-run"
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "ERROR: Unknown flag: $1" >&2
      usage
      ;;
    *)
      break
      ;;
  esac
done

# Remaining arg is the subject
if [[ $# -eq 0 ]]; then
  echo "ERROR: Commit subject is required." >&2
  usage
fi
if [[ $# -gt 1 ]]; then
  echo "ERROR: Too many positional arguments. Quote your subject." >&2
  usage
fi
SUBJECT="$1"

if [[ -z "$SUBJECT" ]]; then
  echo "ERROR: Commit subject cannot be empty." >&2
  exit 1
fi

# ---------------------------------------------------------------------------
# Session ID resolution
# ---------------------------------------------------------------------------

# _pid_get_parent <pid>: print the parent PID of <pid>, or "" on failure.
# Works on Linux (/proc), macOS, and Git Bash on Windows (ps -p ... -o ppid=).
_pid_get_parent() {
  local pid="${1:-}"
  [[ -n "$pid" && "$pid" =~ ^[0-9]+$ ]] || return 1
  local ppid=""
  # /proc is available on Linux and Git Bash on Windows
  if [[ -f "/proc/${pid}/status" ]]; then
    ppid=$(grep -m1 '^PPid:' "/proc/${pid}/status" 2>/dev/null | awk '{print $2}' || true)
  fi
  # Fall back to ps (macOS, BSD)
  if [[ -z "$ppid" ]]; then
    ppid=$(ps -p "$pid" -o ppid= 2>/dev/null | tr -d ' ' || true)
  fi
  [[ -n "$ppid" && "$ppid" =~ ^[0-9]+$ ]] && echo "$ppid" || return 1
}

# _ppid_ancestry: print the ancestry chain of PIDs from $PPID upward, one per
# line, stopping at PID 1 or after at most MAX_DEPTH steps. Used by both the
# sentinel cross-check (W1.1) and the PPID-walk priority (W1.3).
# Spec backlink: plan W1.1 sentinel cross-check + W1.3 PPID-walk discovery.
_ppid_ancestry() {
  local current="$PPID"
  local depth=0
  local max_depth=20
  while [[ -n "$current" && "$current" =~ ^[0-9]+$ && "$current" -gt 1 && "$depth" -lt "$max_depth" ]]; do
    echo "$current"
    current=$(_pid_get_parent "$current" 2>/dev/null || true)
    (( depth++ )) || true
  done
}

# _session_pid_matches_ancestor <sessions_dir> <session_id>
# Returns 0 if meta.json.pid for the given session is alive AND appears in
# this process's PPID ancestry chain. Returns 1 otherwise.
# Used by W1.1 sentinel cross-check.
_session_pid_matches_ancestor() {
  local base="${1:?}" sid="${2:?}"
  local sdir="${base}/${sid}"
  [[ -d "$sdir" ]] || return 1

  local recorded_pid
  recorded_pid=$(_cs_read_meta_field "$sdir" "pid")
  [[ -n "$recorded_pid" && "$recorded_pid" =~ ^[0-9]+$ ]] || return 1

  # Check liveness first (fast exit for dead PIDs)
  _cs_pid_alive "$recorded_pid" || return 1

  # Check that the recorded PID appears in our PPID ancestry chain
  local ancestor
  while IFS= read -r ancestor; do
    [[ "$ancestor" == "$recorded_pid" ]] && return 0
  done < <(_ppid_ancestry)
  return 1
}

resolve_session_id() {
  # Priority 1: environment variable
  if [[ -n "${CLAUDE_SESSION_ID:-}" ]]; then
    echo "$CLAUDE_SESSION_ID"
    return 0
  fi

  local base
  base=$(_cs_sessions_dir) || true

  # Priority 1.5: PPID-walk — walk $PPID upward; for each ancestor, check if
  # any live session's meta.json.pid matches. If exactly one match, use it.
  # This is the highest-leverage resolution path when CLAUDE_SESSION_ID is unset:
  # track-touched-files.sh (W1.0b) records a live $PPID on every hook invocation,
  # giving us a reliable ancestor to find.
  # Spec backlink: plan W1.3 — PPID-based discovery as priority 1.5.
  # NO CLI-token fallback: the Bash tool spawns shells without session-identifiable tokens.
  if [[ -n "$base" && -d "$base" ]]; then
    local ppid_matched_session=""
    local ancestry_pids=()
    # Collect ancestry into an array once to avoid re-walking per session
    while IFS= read -r ancestor_pid; do
      ancestry_pids+=("$ancestor_pid")
    done < <(_ppid_ancestry)

    if [[ ${#ancestry_pids[@]} -gt 0 ]]; then
      for sdir in "${base}"/*/; do
        [[ -d "$sdir" ]] || continue
        local sid
        sid=$(basename "$sdir")
        [[ "$sid" == ".archive" ]] && continue

        local recorded_pid
        recorded_pid=$(_cs_read_meta_field "$sdir" "pid")
        [[ -n "$recorded_pid" && "$recorded_pid" =~ ^[0-9]+$ ]] || continue
        _cs_pid_alive "$recorded_pid" || continue

        # Check ancestry match
        local anc
        for anc in "${ancestry_pids[@]}"; do
          if [[ "$anc" == "$recorded_pid" ]]; then
            if [[ -n "$ppid_matched_session" && "$ppid_matched_session" != "$sid" ]]; then
              # Multiple sessions match PPID ancestry — cannot disambiguate; fall through
              ppid_matched_session="__ambiguous__"
              break 2
            fi
            ppid_matched_session="$sid"
            break
          fi
        done
      done
    fi

    if [[ -n "$ppid_matched_session" && "$ppid_matched_session" != "__ambiguous__" ]]; then
      # Check sentinel for disagreement before accepting (W1.1 disagreement rule)
      local root
      root=$(_cs_git_root) || true
      if [[ -n "$root" ]]; then
        local sentinel="${root}/.git/coordinator-sessions/.current-session-id"
        if [[ -f "$sentinel" ]]; then
          local sentinel_sid
          sentinel_sid=$(cat "$sentinel" 2>/dev/null | tr -d '[:space:]')
          # Sentinel path-traversal validation (W1.1)
          if [[ -n "$sentinel_sid" && ! "$sentinel_sid" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            echo "[coordinator-session] WARN: sentinel contains invalid characters — ignoring (possible path-traversal)" >&2
            sentinel_sid=""
          fi
          # Disagreement rule (Patrik finding #4): if sentinel names a different live
          # session that also has a live PID, hard-fail rather than silently prefer one.
          if [[ -n "$sentinel_sid" && "$sentinel_sid" != "$ppid_matched_session" ]]; then
            local sentinel_sdir="${base}/${sentinel_sid}"
            if [[ -d "$sentinel_sdir" ]]; then
              local sentinel_pid
              sentinel_pid=$(_cs_read_meta_field "$sentinel_sdir" "pid")
              if [[ -n "$sentinel_pid" ]] && _cs_pid_alive "$sentinel_pid"; then
                echo "ERROR: Session ID resolution conflict — PPID-walk resolves to '${ppid_matched_session}' but sentinel points to '${sentinel_sid}' (also live)." >&2
                echo "       Cannot safely choose between them. Set CLAUDE_SESSION_ID explicitly, or use the explicit-path fallback:" >&2
                echo "         git add -- <your-paths>" >&2
                echo "         git commit -m \"<subject>\"" >&2
                return 1
              fi
            fi
          fi
        fi
      fi
      echo "$ppid_matched_session"
      return 0
    fi
  fi

  # Priority 2: sentinel file + cross-check against PPID ancestry (W1.1)
  # The sentinel is read only when PPID-walk found no match or was ambiguous.
  # Path-traversal validation and ancestry cross-check guard against stale/wrong sentinels.
  # Spec backlink: plan W1.1 — sentinel cross-check + path-traversal validation.
  local root
  root=$(_cs_git_root) || true
  if [[ -n "$root" ]]; then
    local sentinel="${root}/.git/coordinator-sessions/.current-session-id"
    if [[ -f "$sentinel" ]]; then
      local sid
      sid=$(cat "$sentinel" 2>/dev/null | tr -d '[:space:]')

      # W1.1: Path-traversal validation — sentinel must match safe identifier pattern
      if [[ -n "$sid" && ! "$sid" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        echo "[coordinator-session] WARN: sentinel value '${sid}' contains invalid characters (possible path-traversal attack) — treating as untrusted" >&2
        sid=""
      fi

      if [[ -n "$sid" && -n "$base" && -d "$base" ]]; then
        # W1.1: Cross-check — sentinel's session must have a live PID in our ancestry
        if _session_pid_matches_ancestor "$base" "$sid"; then
          echo "$sid"
          return 0
        else
          echo "[coordinator-session] WARN: sentinel points to session '${sid}' but its PID is not a live ancestor of this process — treating sentinel as untrusted" >&2
          # Fall through to Priority 3
        fi
      fi
    fi
  fi

  # Priority 3: enumerate live sessions — hard-fail when multiple, accept when exactly one.
  # Multi-live detection runs here rather than only at fall-through: if PPID-walk found
  # nothing and sentinel was untrusted, multiple live sessions means we cannot safely
  # auto-detect. Naming both candidates gives the user actionable information.
  # Spec backlink: plan W1.2 — multi-live hard-fail moved earlier + both candidates named.
  if [[ -z "$base" || ! -d "$base" ]]; then
    echo "ERROR: No session store found. Set CLAUDE_SESSION_ID or ensure a session was initialized." >&2
    echo "Fallback: bypass the helper with explicit-path commit:" >&2
    echo "  git add -- <your-paths>" >&2
    echo "  git commit -m \"<subject>\"" >&2
    return 1
  fi

  local live_sessions=()
  for sdir in "${base}"/*/; do
    [[ -d "$sdir" ]] || continue
    local sid
    sid=$(basename "$sdir")
    [[ "$sid" == ".archive" ]] && continue

    local pid
    pid=$(_cs_read_meta_field "$sdir" "pid")
    if _cs_pid_alive "$pid"; then
      live_sessions+=("$sid")
    fi
  done

  if [[ ${#live_sessions[@]} -eq 1 ]]; then
    # Priority 3a: exactly one live session — safe to auto-detect
    echo "${live_sessions[0]}"
    return 0
  elif [[ ${#live_sessions[@]} -eq 0 ]]; then
    # Priority 3c: no live sessions found
    echo "ERROR: No live session found. Set CLAUDE_SESSION_ID or ensure a session was initialized." >&2
    echo "Fallback: bypass the helper with explicit-path commit:" >&2
    echo "  git add -- <your-paths>" >&2
    echo "  git commit -m \"<subject>\"" >&2
    return 1
  else
    # Priority 3b: multiple live sessions — hard-fail naming both candidates
    local candidate_list
    candidate_list=$(printf '%s, ' "${live_sessions[@]}")
    candidate_list="${candidate_list%, }"
    echo "ERROR: Multiple live sessions found — cannot auto-detect session ID." >&2
    echo "       Candidates: ${candidate_list}" >&2
    echo "       Set CLAUDE_SESSION_ID explicitly, or bypass the helper:" >&2
    echo "         git add -- <your-paths>" >&2
    echo "         git commit -m \"<subject>\"" >&2
    return 1
  fi
}

# ---------------------------------------------------------------------------
# YAML frontmatter parser (for --scope-from)
# ---------------------------------------------------------------------------

# parse_scope_from_frontmatter <file>
# Prints one pathspec per line to stdout.
# Returns 1 if frontmatter is missing or scope: is absent.
parse_scope_from_frontmatter() {
  local fpath="${1:?}"

  if [[ ! -f "$fpath" ]]; then
    echo "ERROR: Handoff file not found: ${fpath}" >&2
    return 1
  fi

  # Read lines between the first two "---" delimiters (YAML frontmatter)
  local in_frontmatter=false
  local started=false
  local in_scope=false
  local found_scope=false
  local scope_entries=()

  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip trailing CR for CRLF-encoded files (Windows handoffs).
    # Without this, "$line" == "---" never matches and the parser silently
    # reports "no scope: field found" — a bug observed across 4+ sessions.
    line="${line%$'\r'}"

    if [[ "$line" == "---" ]]; then
      if [[ "$started" == false ]]; then
        started=true
        in_frontmatter=true
        continue
      elif [[ "$in_frontmatter" == true ]]; then
        in_frontmatter=false
        break
      fi
    fi

    [[ "$in_frontmatter" == false ]] && continue

    # Detect "scope:" key
    if [[ "$line" =~ ^scope:[[:space:]]*$ ]]; then
      in_scope=true
      found_scope=true
      continue
    fi

    # If we are inside scope:, collect list items ("  - value")
    if [[ "$in_scope" == true ]]; then
      if [[ "$line" =~ ^[[:space:]]+\-[[:space:]]+(.+)$ ]]; then
        scope_entries+=("${BASH_REMATCH[1]}")
      elif [[ "$line" =~ ^[a-zA-Z] ]]; then
        # New top-level key — exit scope block
        in_scope=false
      fi
    fi
  done < "$fpath"

  if [[ "$found_scope" == false ]]; then
    echo "ERROR: No 'scope:' field found in YAML frontmatter of ${fpath}" >&2
    return 1
  fi

  if [[ ${#scope_entries[@]} -eq 0 ]]; then
    echo "ERROR: 'scope:' field is present but empty in ${fpath}" >&2
    return 1
  fi

  for entry in "${scope_entries[@]}"; do
    echo "$entry"
  done
  return 0
}

# validate_pathspec <pathspec>
# Returns 0 if the pathspec is safe and git accepts it, 1 if malformed or
# contains a path-traversal attempt.
# Spec backlink: plan W2.1 worker-baseline finding #3 — explicit reject for
# ".." traversal and absolute paths; git ls-files returns empty for out-of-tree
# paths rather than an error, so the rejection must be explicit here.
validate_pathspec() {
  local ps="${1:?}"

  # Reject path traversal: any component containing ".." can escape the repo root.
  if [[ "$ps" == *".."* ]]; then
    echo "ERROR: pathspec '${ps}' contains '..' (path traversal) — rejected" >&2
    return 1
  fi

  # Reject absolute paths: they reference locations outside the working tree.
  if [[ "$ps" == /* ]]; then
    echo "ERROR: pathspec '${ps}' is an absolute path — rejected" >&2
    return 1
  fi

  git ls-files -- "$ps" >/dev/null 2>&1
}

# ---------------------------------------------------------------------------
# Structured pre-commit summary printer
# ---------------------------------------------------------------------------

# print_summary <staged_count> <staged_list_nl> <orphan_count> <orphan_list_nl> <other_count> <other_list_nl>
print_summary() {
  local staged_count="$1"
  local staged_list="$2"
  local orphan_count="$3"
  local orphan_list="$4"
  local other_count="$5"
  local other_list="$6"

  echo "" >&2
  echo "Scope: ${staged_count} file(s) staged" >&2
  if [[ -n "$staged_list" ]]; then
    while IFS= read -r f; do
      [[ -n "$f" ]] && echo "  ${f}" >&2
    done <<< "$staged_list"
  fi

  echo "Orphans (dirty, no session claim): ${orphan_count} file(s) — NOT STAGED" >&2
  if [[ -n "$orphan_list" ]]; then
    while IFS= read -r f; do
      [[ -n "$f" ]] && echo "  ${f}" >&2
    done <<< "$orphan_list"
  fi

  echo "Other-session-owned (excluded): ${other_count} file(s)" >&2
  if [[ -n "$other_list" ]]; then
    while IFS= read -r f; do
      [[ -n "$f" ]] && echo "  ${f}" >&2
    done <<< "$other_list"
  fi
  echo "" >&2
}

# ---------------------------------------------------------------------------
# BLANKET MODE
# ---------------------------------------------------------------------------

do_blanket() {
  local session_id="$1"

  # Carve-out enforcement: only valid from session-start or workday-complete
  local invoking="${CLAUDE_INVOKING_COMMAND:-}"
  local allowed=false

  if [[ "$invoking" == "session-start" || "$invoking" == "workday-complete" ]]; then
    allowed=true
  fi

  # Fallback: inspect parent process command line
  if [[ "$allowed" == false ]]; then
    local ppid_cmd=""
    if [[ -r "/proc/$PPID/cmdline" ]]; then
      ppid_cmd=$(tr '\0' ' ' < "/proc/$PPID/cmdline" 2>/dev/null || true)
    else
      ppid_cmd=$(ps -p "$PPID" -o command= 2>/dev/null || true)
    fi
    if [[ "$ppid_cmd" == *"session-start.md"* || "$ppid_cmd" == *"workday-complete.md"* ]]; then
      allowed=true
    fi
  fi

  if [[ "$allowed" == false ]]; then
    cat >&2 <<'ERR'
ERROR: --blanket is only valid from /session-start or /workday-complete.
Use scoped staging (default) or COORDINATOR_OVERRIDE_SCOPE=1 for emergencies.
ERR
    exit 1
  fi

  # Log this invocation
  local base sdir log_dir
  base=$(_cs_sessions_dir) || true
  if [[ -n "$base" && -n "$session_id" ]]; then
    sdir="${base}/${session_id}"
    mkdir -p "$sdir"
    log_dir="${sdir}/blanket-invocations.log"
    echo "$(_cs_now_iso) invoking_command=${invoking:-unknown}" >> "$log_dir"
  fi

  # Stage everything (this is the ONE sanctioned use of git add -A)
  git add -A
  git commit -m "$SUBJECT"
}

# ---------------------------------------------------------------------------
# SCOPE-FROM MODE
# ---------------------------------------------------------------------------

do_scope_from() {
  local session_id="$1"

  # 1. Verify file exists
  if [[ ! -f "$SCOPE_FROM_PATH" ]]; then
    echo "ERROR: --scope-from path does not exist: ${SCOPE_FROM_PATH}" >&2
    exit 1
  fi

  # 2. Parse frontmatter scope: array
  local handoff_scope_raw
  if ! handoff_scope_raw=$(parse_scope_from_frontmatter "$SCOPE_FROM_PATH"); then
    exit 1
  fi

  local handoff_pathspecs=()
  while IFS= read -r ps; do
    [[ -n "$ps" ]] && handoff_pathspecs+=("$ps")
  done <<< "$handoff_scope_raw"

  # 3. Validate each pathspec
  for ps in "${handoff_pathspecs[@]}"; do
    if ! validate_pathspec "$ps"; then
      echo "ERROR: Malformed or invalid pathspec in scope: '${ps}'" >&2
      exit 1
    fi
  done

  # 4. Expand handoff pathspecs to actual file list, applying one-tier membership
  # invariant for untracked files.
  #
  # One-tier untracked-membership invariant (W2.1, Patrik finding #2):
  #   - Tracked candidates (git ls-files): admitted unconditionally — they are
  #     already in repo history and cannot be a concurrent-session footgun.
  #   - Untracked candidates (git ls-files --others): MUST appear in THIS
  #     session's touched.txt. If they don't, they are dropped here — before
  #     the cross-session subtraction step — regardless of whether the pathspec
  #     is a glob or a literal. A literal like "docs/plans/2026-05-01-mine.md"
  #     can still collide with another session's untracked file at the same path;
  #     glob detection alone does not prevent this.
  # Spec backlink: plan W2.1 — one-tier untracked-membership invariant.

  # Collect my touched.txt first — needed for the membership gate below.
  local my_touched=()
  local base
  base=$(_cs_sessions_dir) || true
  if [[ -n "$base" && -n "$session_id" ]]; then
    local sdir="${base}/${session_id}"
    if [[ -f "${sdir}/touched.txt" ]]; then
      while IFS= read -r t; do
        [[ -n "$t" ]] && my_touched+=("$t")
      done < "${sdir}/touched.txt"
    fi
  fi

  # Build membership lookup for O(1) checks.
  declare -A my_touched_set
  for t in "${my_touched[@]:-}"; do
    [[ -n "$t" ]] && my_touched_set["$t"]=1
  done

  local handoff_files=()
  for ps in "${handoff_pathspecs[@]}"; do
    # Tracked files: admitted unconditionally.
    while IFS= read -r f; do
      [[ -n "$f" ]] && handoff_files+=("$f")
    done < <(git ls-files -- "$ps" 2>/dev/null)

    # Untracked files: membership gate — must be in this session's touched.txt.
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      if [[ -v "my_touched_set[$f]" ]]; then
        handoff_files+=("$f")
      else
        echo "skipping untracked ${f} — not in this session's touched.txt (W2.1 membership gate)" >&2
      fi
    done < <(git ls-files --others --exclude-standard -- "$ps" 2>/dev/null)
  done

  # 5. Build MY_SCOPE: (handoff_files ∪ touched.txt) − other_sessions

  # Union: handoff + touched (deduplicated)
  declare -A candidate_map
  for f in "${handoff_files[@]}" "${my_touched[@]:-}"; do
    [[ -n "$f" ]] && candidate_map["$f"]=1
  done

  # Build other sessions' claim map
  declare -A other_claims
  local other_excluded=()
  if [[ -n "$base" && -d "$base" ]]; then
    for other_sdir in "${base}"/*/; do
      [[ -d "$other_sdir" ]] || continue
      local other_id
      other_id=$(basename "$other_sdir")
      [[ "$other_id" == "$session_id" ]] && continue
      [[ "$other_id" == ".archive" ]] && continue
      if [[ -f "${other_sdir}/touched.txt" ]]; then
        while IFS= read -r opath; do
          [[ -n "$opath" ]] && other_claims["$opath"]="$other_id"
        done < "${other_sdir}/touched.txt"
      fi
    done
  fi

  # Subtract other-session claims
  # W3 (Patrik R1 finding #1): distinguish "another session owns this" from
  # "stale self-claim" when CLAUDE_SESSION_ID is set but resolution diverged.
  # Append "(your session=<resolved>)" for disambiguation in the normal case.
  local my_scope=()
  local env_sid="${CLAUDE_SESSION_ID:-}"
  for candidate in "${!candidate_map[@]}"; do
    if [[ -v "other_claims[$candidate]" ]]; then
      other_excluded+=("$candidate")
      local claim_sid="${other_claims[$candidate]}"
      if [[ -n "$env_sid" && "$claim_sid" == "$env_sid" ]]; then
        echo "skipping ${candidate} — stale self-claim from this session (resolved=${session_id}, env=${env_sid}) — investigate session ID resolution" >&2
      else
        echo "skipping ${candidate} — owned by session ${claim_sid} (your session=${session_id})" >&2
      fi
    else
      my_scope+=("$candidate")
    fi
  done

  # W3 epilogue: when ≥1 file was excluded, point the user at the right diagnostic.
  if [[ ${#other_excluded[@]} -gt 0 ]]; then
    echo "  hint: if your files are being skipped as 'owned by another session' but you wrote them, your session ID resolution is wrong (see ~/.claude/docs/wiki/scoped-safety-commits.md troubleshooting)" >&2
  fi

  if [[ "${MODE}" == "dry-run" ]]; then
    echo "DRY RUN — would stage:" >&2
    for f in "${my_scope[@]:-}"; do echo "  $f" >&2; done
    echo "(no git add or commit executed)" >&2
    exit 0
  fi

  if [[ ${#my_scope[@]} -eq 0 ]]; then
    if [[ ${#other_excluded[@]} -gt 0 ]]; then
      # Every candidate from the handoff scope was claimed by other sessions — stale-claim case.
      # Collect the distinct session IDs that claimed entries so the user can act on them.
      declare -A claiming_sessions
      for excl in "${other_excluded[@]}"; do
        if [[ -v "other_claims[$excl]" ]]; then
          claiming_sessions["${other_claims[$excl]}"]=1
        fi
      done
      local claimant_list
      claimant_list=$(printf '%s ' "${!claiming_sessions[@]}")
      echo "ERROR: Every file in the handoff scope was claimed by other session(s): ${claimant_list}" >&2
      echo "       Files excluded: $(printf '%s, ' "${other_excluded[@]}")" >&2
      echo "       Your session: ${session_id}" >&2
      echo "       If these files are yours, bypass the helper:" >&2
      echo "         git add -- <your-paths>" >&2
      echo "         git commit -m \"<subject>\"" >&2
    else
      echo "ERROR: No staged scope detected for this session. Either nothing was touched, or the touch-tracker hook didn't fire. Run with --dry-run to inspect." >&2
    fi
    exit 1
  fi

  # Stage
  local staged_count=${#my_scope[@]}
  printf '%s\0' "${my_scope[@]}" | xargs -0 git add --
  git commit -m "$SUBJECT"

  print_summary "$staged_count" "$(printf '%s\n' "${my_scope[@]}")" \
    0 "" \
    "${#other_excluded[@]}" "$(printf '%s\n' "${other_excluded[@]:-}")"
}

# ---------------------------------------------------------------------------
# OVERRIDE MODE helper
# ---------------------------------------------------------------------------

do_override() {
  local session_id="$1"

  echo "WARNING: COORDINATOR_OVERRIDE_SCOPE=1 is set — audit-trail-degraded path." >&2
  echo "         Staging all dirty files. This will be logged." >&2

  # Collect dirty files for the log
  local dirty_files=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && dirty_files+=("$f")
  done < <(
    { git diff --name-only HEAD 2>/dev/null; git ls-files --others --exclude-standard 2>/dev/null; } | sort -u
  )

  # Log the override
  local base
  base=$(_cs_sessions_dir) || true
  if [[ -n "$base" && -n "$session_id" ]]; then
    local sdir="${base}/${session_id}"
    mkdir -p "$sdir"
    local log_file="${sdir}/overrides.log"
    {
      echo "=== Override at $(_cs_now_iso) ==="
      echo "Subject: ${SUBJECT}"
      echo "Files staged:"
      printf '  %s\n' "${dirty_files[@]:-}"
      echo ""
    } >> "$log_file"
  fi

  git add -A
  git commit -m "$SUBJECT"
}

# ---------------------------------------------------------------------------
# DEFAULT / DRY-RUN MODE (main scoped path)
# ---------------------------------------------------------------------------

do_scoped() {
  local session_id="$1"

  # Read my touched.txt for post-filtering (mtime-only orphan exclusion)
  # cs_compute_scope adds mtime-dirty unclaimed files to my_scope, but per
  # plan orphan policy those must only be warned, never auto-staged.
  # We enforce this here by removing from my_scope any file that:
  #   - is NOT in my touched.txt
  #   - is NOT claimed by another session (i.e., is an orphan)
  local my_touched=()
  local base
  base=$(_cs_sessions_dir) || true
  if [[ -n "$base" && -n "$session_id" && -f "${base}/${session_id}/touched.txt" ]]; then
    while IFS= read -r t; do
      [[ -n "$t" ]] && my_touched+=("$t")
    done < "${base}/${session_id}/touched.txt"
  fi

  # Capture cs_compute_scope output: stdout = my scope, stderr = skip + orphan messages
  local scope_stdout scope_stderr
  local tmpout tmperr
  tmpout=$(mktemp)
  tmperr=$(mktemp)

  cs_compute_scope "$session_id" > "$tmpout" 2> "$tmperr"

  scope_stdout=$(cat "$tmpout")
  scope_stderr=$(cat "$tmperr")
  rm -f "$tmpout" "$tmperr"

  # Parse raw scope from cs_compute_scope stdout (may include mtime-added orphans)
  local raw_scope=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && raw_scope+=("$line")
  done <<< "$scope_stdout"

  # Post-filter: separate legitimate scope (in my touched.txt) from mtime-only orphans
  # A file is an mtime-only orphan if:
  #   - cs_compute_scope included it (so no other session claims it)
  #   - it is NOT in my touched.txt
  # Per plan orphan policy: warn only, do NOT stage.
  local my_scope=()
  local mtime_orphans=()
  for candidate in "${raw_scope[@]:-}"; do
    [[ -z "$candidate" ]] && continue
    local in_touched=false
    for t in "${my_touched[@]:-}"; do
      [[ "$t" == "$candidate" ]] && { in_touched=true; break; }
    done
    if [[ "$in_touched" == true ]]; then
      my_scope+=("$candidate")
    else
      # Not in my touched.txt — treat as mtime-only orphan
      mtime_orphans+=("$candidate")
    fi
  done

  # Parse other-session exclusions from stderr (skipping ... lines)
  local other_excluded_files=()
  while IFS= read -r line; do
    if [[ "$line" == "skipping "* ]]; then
      other_excluded_files+=("$line")
    fi
  done <<< "$scope_stderr"

  # Merge orphans: library-detected ones (from stderr) + mtime-only ones we post-filtered
  # Library stderr emits "orphan: <path>"; collect those too
  local orphan_files=()
  while IFS= read -r line; do
    if [[ "$line" == "orphan: "* ]]; then
      orphan_files+=("${line#orphan: }")
    fi
  done <<< "$scope_stderr"
  # Add mtime-only orphans that the library didn't mark (it thought they were ours)
  for mto in "${mtime_orphans[@]:-}"; do
    orphan_files+=("$mto")
    echo "orphan (mtime-only, not in touched.txt): ${mto}" >&2
  done

  # Dry-run: print and exit without committing
  if [[ "$MODE" == "dry-run" ]]; then
    echo "DRY RUN — would stage ${#my_scope[@]} file(s):" >&2
    for f in "${my_scope[@]:-}"; do echo "  $f" >&2; done
    if [[ ${#orphan_files[@]} -gt 0 ]]; then
      echo "Orphans (not staged): ${#orphan_files[@]} file(s):" >&2
      for f in "${orphan_files[@]}"; do echo "  $f" >&2; done
    fi
    if [[ ${#other_excluded_files[@]} -gt 0 ]]; then
      echo "Excluded (other-session-owned): ${#other_excluded_files[@]}" >&2
    fi
    echo "(no git add or commit executed)" >&2
    exit 0
  fi

  # Validate we have something to stage
  if [[ ${#my_scope[@]} -eq 0 ]]; then
    echo "ERROR: No staged scope detected for this session. Either nothing was touched, or the touch-tracker hook didn't fire. Run with --dry-run to inspect." >&2
    exit 1
  fi

  # Stage explicitly using xargs -0 to handle spaces in paths
  printf '%s\0' "${my_scope[@]}" | xargs -0 git add --

  # Commit
  if ! git commit -m "$SUBJECT"; then
    echo "ERROR: git commit failed. Staged set: ${my_scope[*]}" >&2
    exit 1
  fi

  # Print structured summary (to stderr so it doesn't pollute capture)
  print_summary \
    "${#my_scope[@]}" \
    "$(printf '%s\n' "${my_scope[@]}")" \
    "${#orphan_files[@]}" \
    "$(printf '%s\n' "${orphan_files[@]:-}")" \
    "${#other_excluded_files[@]}" \
    "$(printf '%s\n' "${other_excluded_files[@]:-}")"
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

main() {
  # Resolve session ID (needed for all modes except dry-run of blanket)
  local session_id=""

  if [[ "$MODE" != "blanket" ]]; then
    # For non-blanket modes we always need a session ID
    if ! session_id=$(resolve_session_id); then
      # Error already printed by resolve_session_id
      exit 1
    fi
    if [[ -z "$session_id" ]]; then
      echo "ERROR: Could not resolve session ID." >&2
      exit 1
    fi
  else
    # For blanket mode, try to resolve for logging purposes, but don't fail if absent
    session_id=$(resolve_session_id 2>/dev/null) || session_id=""
  fi

  # COORDINATOR_OVERRIDE_SCOPE=1 intercepts default mode only
  if [[ "${COORDINATOR_OVERRIDE_SCOPE:-}" == "1" && "$MODE" == "default" ]]; then
    do_override "$session_id"
    exit 0
  fi

  case "$MODE" in
    blanket)
      do_blanket "$session_id"
      ;;
    scope-from)
      do_scope_from "$session_id"
      ;;
    dry-run)
      do_scoped "$session_id"
      ;;
    default)
      do_scoped "$session_id"
      ;;
    *)
      echo "ERROR: Unknown mode: ${MODE}" >&2
      exit 1
      ;;
  esac
}

main "$@"
